{
  "serviceAccountKeyPath": "/etc/kiosk/google-service-account.json",
  "pollIntervalSeconds": 120,
  "socketPath": "/run/kiosk/calendar-sync.sock",
  "snapshotPath": "/run/kiosk/calendar-snapshot.json",
  "calendars": [
    { "calendarId": "family@example.com", "color": "#9085e9" }
  ],
  "people": [
    { "person": "Sharon", "color": "#fbd75b", "emails": ["kiosk-sync+sharon@your-project.iam.gserviceaccount.com"] },
    { "person": "Donald", "color": "#46d6db", "emails": ["kiosk-sync+donald@your-project.iam.gserviceaccount.com"] },
    { "person": "Mum", "color": "#3987e5", "emails": ["kiosk-sync+mum@your-project.iam.gserviceaccount.com", "mum@example.com"] },
    { "person": "Dad", "color": "#e66550", "emails": ["kiosk-sync+dad@your-project.iam.gserviceaccount.com", "dad@example.com"] }
  ]
}
